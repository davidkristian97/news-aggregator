                        "description": "Unauthenticated"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "put": {
                "tags": [
                    "Me"
                ],
                "summary": "Update the authenticated user's preferences",
                "operationId": "46055d576d7b68ea2ed7dfad89daa670",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "source_ids": {
                                        "type": "array",
                                        "items": {
                                            "type": "integer"
