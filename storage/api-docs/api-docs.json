            "get": {
                "tags": [
                    "Filters"
                ],
                "summary": "Search authors by name",
                "operationId": "1c8daa3d9f89695e8782b015405c66fe",
                "parameters": [
                    {
                        "name": "q",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "string"
                        },
                        "example": "John"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Matching authors",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
